      "parameters": {
        "url": "=https://api.apify.com/v2/datasets/{{ $node[\"Check Scraper Status\"].json.data.defaultDatasetId }}/items?token={{ $node[\"Webhook Trigger\"].json.headers[\"x-apify-token\"] || \"YOUR_APIFY_TOKEN\" }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        240
      ],
      "id": "apify-get-dataset",
      "name": "Get Download Link"
    },
    {
      "parameters": {
        "url": "={{ $json[0].videoUrl }}",
        "responseFormat": "file",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        240
      ],
      "id": "download-video",
      "name": "Download Video Bin"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/audio/transcriptions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $node[\"Webhook Trigger\"].json.headers[\"x-openai-key\"] || \"YOUR_OPENAI_KEY\" }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyFormat": "form-data",
        "formDataParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "whisper-1"
            },
            {
              "name": "file",
              "parameterType": "formBinaryData",
              "inputDataFieldName": "data"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        240
      ],
      "id": "openai-whisper",
      "name": "OpenAI Whisper API"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.tavily.com/search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"api_key\": \"{{ $node[\"Webhook Trigger\"].json.headers[\"x-tavily-key\"] || \"YOUR_TAVILY_KEY\" }}\",\n  \"query\": \"{{ $node[\"OpenAI Whisper API\"].json.text.substring(0, 100) }} India news\",\n  \"search_depth\": \"advanced\",\n  \"max_results\": 15\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        240
      ],
      "id": "tavily-search",
      "name": "Tavily Search API"
    },
    {
      "parameters": {
        "respondWith": "allIncomingItems",
        "options": {}
