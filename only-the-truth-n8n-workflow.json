    {
      "parameters": {
        "url": "=https://api.apify.com/v2/acts/haas~instagram-downloader/runs/{{ $node[\"Trigger Apify Scraper\"].json.data.id }}?token={{ $node[\"Webhook Trigger\"].json.headers[\"x-apify-token\"] || \"YOUR_APIFY_TOKEN\" }}",
        "options": {}
