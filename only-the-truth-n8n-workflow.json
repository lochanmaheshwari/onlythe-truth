          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $node[\"Webhook Trigger\"].json.headers[\"x-apify-token\"] || \"YOUR_APIFY_TOKEN\" }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"directUrls\": [ \"{{ $json.body.instagramUrl }}\" ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        240
      ],
      "id": "apify-trigger",
      "name": "Trigger Apify Scraper"
    },
